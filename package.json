{
  "name": "mentorly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "convex dev --start 'next dev --webpack'",
    "dev:turbo": "convex dev --start 'next dev --turbopack'",
    "dev:web": "next dev --webpack",
    "dev:web:turbo": "next dev --turbopack",
    "dev:convex": "convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.7",
    "convex": "^1.39.1",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
